---
import ArchitectureDiagram from "../components/ArchitectureDiagram.astro";
import BenchmarkEvidence from "../components/BenchmarkEvidence.astro";
import Callout from "../components/Callout.astro";
import CodeBlock from "../components/CodeBlock.astro";
import FeatureGrid from "../components/FeatureGrid.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const features = [
  {
    title: "Semantic token coverage",
    text: "Components consume named roles for text, surfaces, borders, accents, focus, code, and diagrams.",
  },
  {
    title: "Static interaction boundary",
    text: "The only client script in this phase is the guarded framework-free Light, Dark, and System preference control.",
  },
  {
    title: "Truthful temporary content",
    text: "This page demonstrates Phase 2 layout behavior without adding the Phase 3 Markdown or MDX content set.",
  },
];

const code = `# Temporary Phase 2 demonstration
uv tool install irigate
irigate --config profiles/mvp.yaml --check
irigate serve --config profiles/mvp.yaml`;
---

<BaseLayout
  title="Irigate"
  description="A temporary Phase 2 layout demonstration for the Irigate static Astro site."
>
  <section class="hero section shell">
    <div class="hero__copy">
      <p class="eyebrow">Phase 2 layout demonstration</p>
      <h1>Share local MCP servers across your AI coding agents.</h1>
      <p class="lede">
        This temporary page exercises the site shell, theme contract, token palette, and shared components.
        Final product copy and Markdown/MDX content belong to Phase 3.
      </p>
      <div class="button-row">
        <a class="button" data-variant="primary" href="#theme-contract">Inspect theme contract</a>
        <a class="button" href="#layout-components">View components</a>
      </div>
    </div>
    <CodeBlock label="Current command shape" code={code} />
  </section>

  <section id="theme-contract" class="section shell split">
    <div>
      <p class="eyebrow">Theme behavior</p>
      <h2>Light, Dark, and System are explicit choices.</h2>
    </div>
    <Callout title="Phase 2 contract" tone="note">
      <p>
        The effective theme is written as <code>data-theme="light|dark"</code> on the root element.
        The stored preference is <code>irigate.theme</code>, with guarded storage access and live OS
        response only while System is selected.
      </p>
    </Callout>
  </section>

  <section id="layout-components" class="section shell stack">
    <div class="section-heading">
      <p class="eyebrow">Reusable layout pieces</p>
      <h2>Editorial surfaces for later content.</h2>
    </div>
    <FeatureGrid features={features} />
    <ArchitectureDiagram />
    <BenchmarkEvidence />
    <Callout title="Claim boundary" tone="boundary">
      <p>
        This demonstration does not claim universal memory savings, latency improvements, remote access,
        enterprise governance, compliance, or authentication.
      </p>
    </Callout>
  </section>
</BaseLayout>

<style>
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(18rem, 0.95fr);
    gap: var(--space-7);
    align-items: center;
  }

  .hero__copy,
  .stack,
  .section-heading {
    display: grid;
    gap: var(--space-5);
  }

  .split {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(18rem, 1.1fr);
    gap: var(--space-6);
    align-items: start;
  }

  @media (max-width: 52rem) {
    .hero,
    .split {
      grid-template-columns: 1fr;
    }
  }
</style>
