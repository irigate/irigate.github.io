---
import { getEntry, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const entry = await getEntry("pages", "home");
if (!entry) {
  throw new Error("Missing home page content entry");
}

const { Content } = await render(entry);
---

<BaseLayout
  title={entry.data.title}
  description={entry.data.description}
  seoDescription={entry.data.seoDescription}
  path={entry.data.route.path}
  jsonLd="software"
>
  <Content />
</BaseLayout>

<style>
  :global(.hero),
  :global(.quick-start__grid),
  :global(.boundary-grid),
  :global(.steps),
  :global(.final-cta) {
    display: grid;
    gap: var(--space-6);
  }

  :global(.hero) {
    grid-template-columns: minmax(0, 1.05fr) minmax(18rem, 0.95fr);
    align-items: center;
  }

  :global(.hero__copy),
  :global(.stack),
  :global(.section-heading) {
    display: grid;
    gap: var(--space-5);
  }

  :global(.hero__lockup) {
    width: min(100%, 25rem);
    height: auto;
  }

  :global(.hero__proof) {
    max-width: 42rem;
    border-left: 3px solid var(--color-accent);
    padding-left: var(--space-4);
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  :global(.hero__proof strong) {
    color: var(--color-text);
  }

  :global(.hero__visual) {
    position: relative;
    isolation: isolate;
    min-width: 0;
    padding: clamp(2rem, 7vw, 5rem) 0 0 clamp(1rem, 4vw, 3rem);
  }

  :global(.hero__visual > figure) {
    position: relative;
    z-index: 1;
    box-shadow: var(--shadow-2);
  }

  :global(.hero__watermark) {
    position: absolute;
    z-index: 0;
    top: -1.5rem;
    right: -1rem;
    width: clamp(11rem, 28vw, 19rem);
    height: auto;
    opacity: 0.22;
    filter: saturate(0.85);
    pointer-events: none;
    user-select: none;
  }

  :global(.section-heading p),
  :global(.steps li),
  :global(.quick-start p),
  :global(.final-cta p) {
    color: var(--color-text-muted);
  }

  :global(.steps) {
    grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.2fr);
    align-items: start;
  }

  :global(.steps ol) {
    display: grid;
    gap: var(--space-4);
    margin: 0;
    padding-left: var(--space-5);
  }

  :global(.quick-start__grid) {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  :global(.boundary-grid) {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  :global(.final-cta) {
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
  }

  @media (max-width: 52rem) {
    :global(.hero),
    :global(.steps),
    :global(.quick-start__grid),
    :global(.boundary-grid),
    :global(.final-cta) {
      grid-template-columns: minmax(0, 1fr);
    }

    :global(.final-cta .button) {
      justify-self: start;
    }

    :global(.hero__visual) {
      padding-top: var(--space-7);
      padding-left: 0;
    }

    :global(.hero__watermark) {
      right: 0;
      width: min(48vw, 13rem);
    }
  }
</style>
