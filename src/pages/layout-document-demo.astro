---
import Callout from "../components/Callout.astro";
import DocumentLayout from "../layouts/DocumentLayout.astro";
---

<DocumentLayout
  title="Document Layout Demo"
  description="Temporary Phase 2 page used to verify the shared documentation layout before Markdown content exists."
  eyebrow="Phase 2 verification"
>
  <p>
    This route is intentionally temporary. It verifies reading width, document headings, focusable links,
    print behavior, and the shared site shell without adding Phase 3 documentation content.
  </p>

  <h2>Layout Contract</h2>
  <p>
    The documentation layout keeps one page title, ordinary HTML content, semantic landmarks from the base
    layout, and readable text in light mode, dark mode, no-JavaScript fallback, and print output.
  </p>

  <Callout title="Content boundary" tone="boundary">
    <p>Final docs pages and Markdown collections are deliberately left for Phase 3.</p>
  </Callout>
</DocumentLayout>
