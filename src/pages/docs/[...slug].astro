---
import { getCollection, render } from "astro:content";
import DocumentLayout from "../../layouts/DocumentLayout.astro";

export async function getStaticPaths() {
  const entries = await getCollection("docs");

  return entries.map((entry) => ({
    params: { slug: entry.data.route.slug || undefined },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const faqItems = entry.data.route.slug === "faq"
  ? [
      {
        question: "What is an MCP broker?",
        answer: "An MCP broker sits between MCP clients and MCP servers. Irigate exposes a local Streamable HTTP endpoint to AI coding agents and supervises configured stdio MCP upstreams behind it.",
      },
      {
        question: "Why share local MCP servers?",
        answer: "Several agent sessions can otherwise launch duplicate copies of the same stdio MCP server. When an upstream is safe to share, one broker-managed process can reduce duplicate child processes and resident memory on the workstation.",
      },
      {
        question: "Is every MCP server safe to share?",
        answer: "No. Some MCP servers retain client-specific state, credentials, workspace context, or other session assumptions. Irigate isolates upstreams by default and admits shared mode only when sharing is explicitly requested and qualified.",
      },
      {
        question: "Does Irigate send data to a cloud service?",
        answer: "Irigate does not require an Irigate cloud service. It runs locally and exposes a loopback endpoint. Configured upstream commands may use their own network services or package downloads, so review each upstream separately.",
      },
      {
        question: "Is Irigate an MCP gateway?",
        answer: "It is a local MCP broker and has protocol-forwarding overlap with gateways, but the MVP is not an enterprise gateway. It does not provide remote access, authenticated identity, RBAC, central administration, Kubernetes deployment, or model API proxying.",
      },
      {
        question: "How is it different from enterprise MCP gateways?",
        answer: "Enterprise gateways usually focus on managed deployment, identity, authorization, control planes, portals, and platform telemetry. Irigate focuses on local developer workstations, stdio process supervision, qualified sharing, and metadata-only local reports.",
      },
      {
        question: "Which coding agents work with it?",
        answer: "Current compatibility evidence validated one direct Streamable HTTP broker call from Hermes, Kilo/OpenCode, and Codex. Claude Code was installed but unavailable because the local CLI was not authenticated.",
      },
      {
        question: "Does it improve latency?",
        answer: "No latency improvement is claimed from the current evidence. The benchmark's Context7 calls were upstream-throttled, and an unthrottled 20-client diagnostic produced repeated 30-second timeouts and degradation.",
      },
    ]
  : undefined;
---

<DocumentLayout
  title={entry.data.title}
  description={entry.data.description}
  seoDescription={entry.data.seoDescription}
  path={entry.data.route.path}
  jsonLd={entry.data.route.slug === "faq" ? "faq" : undefined}
  faqItems={faqItems}
>
  <Content />
</DocumentLayout>
