---
import ThemeSwitcher from "./ThemeSwitcher.astro";
---

<header class="site-header">
  <div class="site-header__inner shell">
    <a class="brand" href="/" aria-label="Irigate home">
      <img class="brand__mark" src="/logo-mark.svg" alt="" width="32" height="32" />
      <span class="brand__name">Irigate</span>
    </a>
    <nav class="site-nav" aria-label="Primary">
      <a href="/docs/">Docs</a>
      <a href="/benchmarks/">Benchmarks</a>
      <a href="https://github.com/irigate/irigate-mcp-proxy">GitHub</a>
    </nav>
    <ThemeSwitcher />
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-background) 92%, transparent);
  }

  .site-header__inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: var(--space-4);
    align-items: center;
    padding-block: var(--space-4);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-text);
    font-weight: 800;
    text-decoration: none;
  }

  .brand__mark {
    width: 2rem;
    height: 2rem;
    flex: 0 0 auto;
  }

  .brand__name {
    font-family: var(--font-display);
    font-size: 1.25rem;
  }

  .site-nav {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-4);
    justify-content: flex-end;
  }

  .site-nav a {
    color: var(--color-text-muted);
    font-weight: 700;
    text-decoration: none;
  }

  .site-nav a:hover {
    color: var(--color-text);
  }

  @media (max-width: 52rem) {
    .site-header__inner {
      grid-template-columns: 1fr;
      align-items: stretch;
    }

    .site-nav {
      justify-content: flex-start;
    }
  }
</style>
