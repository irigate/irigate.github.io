---
export interface Props {
  title: string;
  description: string;
  path?: string;
  jsonLd?: "software" | "faq";
  faqItems?: Array<{ question: string; answer: string }>;
}

const {
  title,
  description,
  path = Astro.url.pathname,
  jsonLd,
  faqItems = [],
} = Astro.props;

const site = Astro.site ?? new URL("https://irigate.io");
const canonical = new URL(path, site).toString();
const ogImage = new URL("/og-default.png", site).toString();
const favicon = new URL("/favicon.svg", site).toString();
const sitemap = new URL("/sitemap-index.xml", site).toString();
const pageTitle = title === "Irigate" ? "Irigate" : `${title} | Irigate`;

const structuredData = jsonLd === "software"
  ? {
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      name: "Irigate",
      description,
      applicationCategory: "DeveloperApplication",
      operatingSystem: "Linux, macOS, Windows",
      url: new URL("/", site).toString(),
      codeRepository: "https://github.com/irigate/irigate-mcp-proxy",
    }
  : jsonLd === "faq"
    ? {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        mainEntity: faqItems.map((item) => ({
          "@type": "Question",
          name: item.question,
          acceptedAnswer: {
            "@type": "Answer",
            text: item.answer,
          },
        })),
      }
    : undefined;
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="description" content={description} />
<title>{pageTitle}</title>
<link rel="canonical" href={canonical} />
<link rel="icon" href={favicon} type="image/svg+xml" />
<link rel="sitemap" href={sitemap} type="application/xml" />
<meta property="og:type" content="website" />
<meta property="og:site_name" content="Irigate" />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content="Irigate local MCP broker social cover" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />
{structuredData && <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>}
