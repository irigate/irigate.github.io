---
export interface Props {
  mode?: "demo";
}
---

<figure class="architecture" aria-labelledby="architecture-title">
  <figcaption id="architecture-title">Temporary Phase 2 architecture motif</figcaption>
  <div class="architecture__grid">
    <div class="architecture__node">
      <span>Agents</span>
      <strong>Codex / Claude / IDE</strong>
    </div>
    <div class="architecture__line" aria-hidden="true"></div>
    <div class="architecture__node architecture__node--broker">
      <span>Loopback broker</span>
      <strong>Streamable HTTP</strong>
    </div>
    <div class="architecture__line" aria-hidden="true"></div>
    <div class="architecture__node">
      <span>Upstreams</span>
      <strong>qualified or isolated</strong>
    </div>
  </div>
</figure>

<style>
  .architecture {
    margin: 0;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2);
    padding: var(--space-5);
    background: var(--color-surface);
    box-shadow: var(--shadow-1);
  }

  .architecture figcaption {
    margin-bottom: var(--space-4);
    color: var(--color-text-muted);
    font-size: 0.9rem;
    font-weight: 700;
  }

  .architecture__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 2rem minmax(0, 1fr) 2rem minmax(0, 1fr);
    gap: var(--space-3);
    align-items: center;
  }

  .architecture__node {
    min-height: 8rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2);
    padding: var(--space-4);
    background: var(--color-surface-raised);
  }

  .architecture__node--broker {
    border-color: var(--color-accent);
    background: var(--color-accent-soft);
  }

  .architecture__node span {
    display: block;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.82rem;
  }

  .architecture__node strong {
    display: block;
    margin-top: var(--space-3);
    font-size: 1.05rem;
    line-height: 1.35;
  }

  .architecture__line {
    height: 2px;
    background: var(--color-diagram-line);
  }

  @media (max-width: 46rem) {
    .architecture__grid {
      grid-template-columns: 1fr;
    }

    .architecture__line {
      width: 2px;
      height: 2rem;
      justify-self: center;
    }
  }
</style>
