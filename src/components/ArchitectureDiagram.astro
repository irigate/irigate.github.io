---
export interface Props {
  variant?: "before-after" | "flow";
}

const { variant = "flow" } = Astro.props;
---

<figure class="architecture" aria-labelledby="architecture-title">
  <figcaption id="architecture-title">
    {variant === "before-after" ? "Before and after local MCP process routing" : "Irigate routing model"}
  </figcaption>
  {variant === "before-after" ? (
    <div class="architecture__compare">
      <div class="architecture__panel">
        <h3>Before</h3>
        <p>Each AI coding agent launches its own stdio MCP server process.</p>
        <div class="architecture__mini" aria-label="Three agents each connected to a duplicate server">
          <span>Agent</span><span>stdio server</span>
          <span>Agent</span><span>stdio server</span>
          <span>Agent</span><span>stdio server</span>
        </div>
      </div>
      <div class="architecture__panel architecture__panel--broker">
        <h3>After</h3>
        <p>Agents connect to one loopback Streamable HTTP broker; upstreams stay qualified-shared or session-isolated.</p>
        <div class="architecture__mini" aria-label="Three agents routed through one broker to qualified or isolated upstreams">
          <span>Agents</span><span>Irigate broker</span>
          <span>qualified shared</span><span>session isolated</span>
        </div>
      </div>
    </div>
  ) : (
    <div class="architecture__grid">
      <div class="architecture__node">
        <span>Agents</span>
        <strong>Hermes / Claude Code / Codex</strong>
      </div>
      <div class="architecture__line" aria-hidden="true"></div>
      <div class="architecture__node architecture__node--broker">
        <span>Loopback broker</span>
        <strong>Streamable HTTP</strong>
      </div>
      <div class="architecture__line" aria-hidden="true"></div>
      <div class="architecture__node">
        <span>Upstreams</span>
        <strong>qualified shared or isolated</strong>
      </div>
    </div>
  )}
</figure>

<style>
  .architecture {
    margin: 0;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2);
    padding: var(--space-5);
    background: var(--color-surface);
    box-shadow: var(--shadow-1);
  }

  .architecture figcaption {
    margin-bottom: var(--space-4);
    color: var(--color-text-muted);
    font-size: 0.9rem;
    font-weight: 700;
  }

  .architecture__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 2rem minmax(0, 1fr) 2rem minmax(0, 1fr);
    gap: var(--space-3);
    align-items: center;
  }

  .architecture__compare {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-4);
  }

  .architecture__panel {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2);
    padding: var(--space-4);
    background: var(--color-surface-raised);
  }

  .architecture__panel--broker {
    border-color: var(--color-accent);
    background: var(--color-accent-soft);
  }

  .architecture__panel h3 {
    font-family: var(--font-body);
    font-size: 1rem;
  }

  .architecture__panel p {
    margin-top: var(--space-2);
    color: var(--color-text-muted);
  }

  .architecture__mini {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-2);
    margin-top: var(--space-4);
  }

  .architecture__mini span {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-1);
    padding: var(--space-2);
    background: var(--color-surface);
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.78rem;
  }

  .architecture__node {
    min-height: 8rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-2);
    padding: var(--space-4);
    background: var(--color-surface-raised);
  }

  .architecture__node--broker {
    border-color: var(--color-accent);
    background: var(--color-accent-soft);
  }

  .architecture__node span {
    display: block;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.82rem;
  }

  .architecture__node strong {
    display: block;
    margin-top: var(--space-3);
    font-size: 1.05rem;
    line-height: 1.35;
  }

  .architecture__line {
    height: 2px;
    background: var(--color-diagram-line);
  }

  @media (max-width: 46rem) {
    .architecture__compare,
    .architecture__grid {
      grid-template-columns: 1fr;
    }

    .architecture__line {
      width: 2px;
      height: 2rem;
      justify-self: center;
    }
  }
</style>
